# Voice Memos — optional notification targets.
# Copy this file to `.env` in the SAME directory and fill in your own values.
# Without these, transcription / search / summary still work — only Telegram/Discord
# sending is skipped (graceful, no error).

# Telegram: create a bot via https://t.me/BotFather to get the token,
# and get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord: an incoming webhook URL for the target channel.
DISCORD_WEBHOOK_URL=
